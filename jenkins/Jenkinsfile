// ============================================================
// Jenkinsfile — Multi-Workspace Databricks Pipeline
// Repo   : https://github.com/ID-KARTHIKEYAN/DATA_INTEGRATION
// Purpose: Trigger ETL jobs across multiple Databricks workspaces
// ============================================================

pipeline {

    agent any

    parameters {

        choice(
            name: 'WORKSPACE',
            choices: [
                'ALL',
                'karthik_workspace',
                'user2_workspace',
                'user3_workspace'
            ],
            description: 'Select target workspace'
        )

        string(
            name: 'GROUP_ID',
            defaultValue: '',
            description: 'Enter GROUP_ID'
        )

        booleanParam(
            name: 'SYNC_GIT',
            defaultValue: true,
            description: 'Sync latest GitHub code to Databricks Repo'
        )

        booleanParam(
            name: 'WAIT_FOR_COMPLETION',
            defaultValue: true,
            description: 'Wait until Databricks run completes'
        )
    }

    environment {

        GITHUB_REPO   = 'https://github.com/ID-KARTHIKEYAN/DATA_INTEGRATION.git'
        GITHUB_BRANCH = 'main'

        POLL_INTERVAL = '15'
        MAX_WAIT_SECS = '1800'
    }

    stages {

        // ============================================================
        // Stage 1 — Validate Parameters
        // ============================================================

        stage('Validate Parameters') {

            steps {

                script {

                    if (!params.GROUP_ID?.trim()) {

                        error "❌ GROUP_ID must not be empty."

                    }

                    echo "=================================================="
                    echo "GROUP_ID            : ${params.GROUP_ID}"
                    echo "WORKSPACE           : ${params.WORKSPACE}"
                    echo "SYNC_GIT            : ${params.SYNC_GIT}"
                    echo "WAIT_FOR_COMPLETION : ${params.WAIT_FOR_COMPLETION}"
                    echo "=================================================="
                }
            }
        }

        // ============================================================
        // Stage 2 — Checkout Repo
        // ============================================================

        stage('Checkout Repo') {

            steps {

                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${env.GITHUB_BRANCH}"]],
                    userRemoteConfigs: [[
                        url: env.GITHUB_REPO,
                        credentialsId: 'GITHUB_CREDENTIALS'
                    ]]
                ])

                echo "✅ GitHub repository checked out successfully"
            }
        }

        // ============================================================
        // Stage 3 — Load Workspace Registry
        // ============================================================

        stage('Load Workspace Registry') {

            steps {

                script {

                    def registryText = readFile('workspaces.json')

                    def registry = readJSON text: registryText

                    def selected = registry.workspaces.findAll { ws ->

                        ws.is_active &&
                        (
                            params.WORKSPACE == 'ALL' ||
                            ws.name == params.WORKSPACE
                        )
                    }

                    if (selected.isEmpty()) {

                        error "❌ No active workspaces found."

                    }

                    env.SELECTED_WORKSPACES =
                        writeJSON(returnText: true, json: selected)

                    echo "✅ Selected Workspaces:"
                    selected.each {
                        echo "   - ${it.name}"
                    }
                }
            }
        }

        // ============================================================
        // Stage 4 — Sync Git Repos
        // ============================================================

        stage('Sync Git Repos') {

            when {
                expression { return params.SYNC_GIT }
            }

            steps {

                script {

                    def workspaces =
                        readJSON text: env.SELECTED_WORKSPACES

                    workspaces.each { ws ->

                        echo "--------------------------------------------------"
                        echo "🔄 Syncing Repo for: ${ws.name}"
                        echo "--------------------------------------------------"

                        withCredentials([
                            string(
                                credentialsId: ws.credential_id,
                                variable: 'DB_TOKEN'
                            )
                        ]) {

                            // =================================================
                            // STEP 1 — GET REPO LIST
                            // =================================================

                            def repoResponse = sh(
                                returnStdout: true,
                                script: """
                                    curl -s \\
                                    -X GET '${ws.workspace_url}/api/2.0/repos' \\
                                    -H 'Authorization: Bearer \$DB_TOKEN'
                                """
                            ).trim()

                            def repoJson = readJSON text: repoResponse

                            def repo = repoJson.repos.find {

                                it.path == ws.github_repo_path

                            }

                            if (!repo) {

                                echo "⚠️ Repo not found:"
                                echo "   ${ws.github_repo_path}"

                                echo "ℹ️ Continuing pipeline..."

                                return
                            }

                            def repoId = repo.id

                            echo "✅ Repo ID Found: ${repoId}"

                            // =================================================
                            // STEP 2 — PATCH REPO
                            // =================================================

                            def syncResponse = sh(
                                returnStdout: true,
                                script: """
                                    curl -s -w "\\n%{http_code}" \\
                                    -X PATCH '${ws.workspace_url}/api/2.0/repos/${repoId}' \\
                                    -H 'Authorization: Bearer \$DB_TOKEN' \\
                                    -H 'Content-Type: application/json' \\
                                    -d '{
                                        "branch": "${env.GITHUB_BRANCH}"
                                    }'
                                """
                            ).trim()

                            def lines =
                                syncResponse.split('\n')

                            def httpCode =
                                lines[-1]

                            def body =
                                lines[0..-2].join('\n')

                            if (httpCode != '200') {

                                echo "⚠️ Git Sync Failed"
                                echo "Workspace : ${ws.name}"
                                echo "HTTP Code : ${httpCode}"
                                echo "Response  : ${body}"

                            } else {

                                echo "✅ Git Sync Successful"
                            }
                        }
                    }
                }
            }
        }

        // ============================================================
        // Stage 5 — Trigger Databricks Jobs
        // ============================================================

        stage('Trigger Databricks Jobs') {

            steps {

                script {

                    def workspaces =
                        readJSON text: env.SELECTED_WORKSPACES

                    def parallelMap = [:]

                    def runIds = [:]

                    workspaces.each { ws ->

                        parallelMap[ws.name] = {

                            withCredentials([
                                string(
                                    credentialsId: ws.credential_id,
                                    variable: 'DB_TOKEN'
                                )
                            ]) {

                                echo "🚀 Triggering Job"
                                echo "Workspace : ${ws.name}"
                                echo "Job ID    : ${ws.job_id}"

                                def triggerResponse = sh(
                                    returnStdout: true,
                                    script: """
                                        curl -s -w "\\n%{http_code}" \\
                                        -X POST '${ws.workspace_url}/api/2.1/jobs/run-now' \\
                                        -H 'Authorization: Bearer \$DB_TOKEN' \\
                                        -H 'Content-Type: application/json' \\
                                        -d '{
                                            "job_id": ${ws.job_id},
                                            "job_parameters": {
                                                "GROUP_ID": "${params.GROUP_ID}"
                                            }
                                        }'
                                    """
                                ).trim()

                                def lines =
                                    triggerResponse.split('\n')

                                def httpCode =
                                    lines[-1]

                                def body =
                                    lines[0..-2].join('\n')

                                if (httpCode != '200') {

                                    error """
❌ Failed to trigger job

Workspace : ${ws.name}
HTTP Code : ${httpCode}

Response:
${body}
"""
                                }

                                def resp =
                                    readJSON text: body

                                def runId =
                                    resp.run_id

                                echo "✅ Run Triggered"
                                echo "Run ID : ${runId}"

                                runIds[ws.name] = [
                                    run_id       : runId,
                                    workspace_url: ws.workspace_url,
                                    credential_id: ws.credential_id
                                ]
                            }
                        }
                    }

                    parallel parallelMap

                    env.RUN_IDS =
                        writeJSON(returnText: true, json: runIds)
                }
            }
        }

        // ============================================================
        // Stage 6 — Wait For Completion
        // ============================================================

        stage('Wait For Completion') {

            when {
                expression {
                    return params.WAIT_FOR_COMPLETION
                }
            }

            steps {

                script {

                    def runIds =
                        readJSON text: env.RUN_IDS

                    def allPassed = true

                    def failedList = []

                    runIds.each { wsName, info ->

                        echo "⏳ Polling Run Status: ${wsName}"

                        withCredentials([
                            string(
                                credentialsId: info.credential_id,
                                variable: 'DB_TOKEN'
                            )
                        ]) {

                            def elapsed = 0
                            def done = false

                            def resultState = ''
                            def lifeCycle = ''

                            while (
                                !done &&
                                elapsed < Integer.parseInt(env.MAX_WAIT_SECS)
                            ) {

                                sleep(
                                    Integer.parseInt(env.POLL_INTERVAL)
                                )

                                elapsed +=
                                    Integer.parseInt(env.POLL_INTERVAL)

                                def statusResponse = sh(
                                    returnStdout: true,
                                    script: """
                                        curl -s \\
                                        -X GET '${info.workspace_url}/api/2.1/jobs/runs/get?run_id=${info.run_id}' \\
                                        -H 'Authorization: Bearer \$DB_TOKEN'
                                    """
                                ).trim()

                                def statusJson =
                                    readJSON text: statusResponse

                                lifeCycle =
                                    statusJson.state?.life_cycle_state ?: 'UNKNOWN'

                                resultState =
                                    statusJson.state?.result_state ?: ''

                                echo """
Workspace : ${wsName}
Lifecycle : ${lifeCycle}
Result    : ${resultState}
"""

                                if (
                                    [
                                        'TERMINATED',
                                        'SKIPPED',
                                        'INTERNAL_ERROR'
                                    ].contains(lifeCycle)
                                ) {

                                    done = true
                                }
                            }

                            if (!done) {

                                echo "⚠️ Timeout : ${wsName}"

                                failedList << "${wsName} (TIMEOUT)"

                                allPassed = false

                            } else if (resultState != 'SUCCESS') {

                                echo "❌ Failed : ${wsName}"

                                failedList <<
                                    "${wsName} (${resultState})"

                                allPassed = false

                            } else {

                                echo "✅ Success : ${wsName}"
                            }
                        }
                    }

                    if (!allPassed) {

                        error """
❌ Some workspaces failed

${failedList.join('\n')}
"""
                    }

                    echo "🎉 All workspaces completed successfully!"
                }
            }
        }
    }

    // ============================================================
    // POST
    // ============================================================

    post {

        always {

            echo """
╔══════════════════════════════════════════════╗
║              PIPELINE SUMMARY               ║
╠══════════════════════════════════════════════╣
║ GROUP_ID  : ${params.GROUP_ID}
║ WORKSPACE : ${params.WORKSPACE}
║ SYNC_GIT  : ${params.SYNC_GIT}
║ STATUS    : ${currentBuild.currentResult}
╚══════════════════════════════════════════════╝
"""
        }

        success {

            echo "✅ PIPELINE SUCCESS"
        }

        failure {

            echo "❌ PIPELINE FAILED"
        }
    }
}
