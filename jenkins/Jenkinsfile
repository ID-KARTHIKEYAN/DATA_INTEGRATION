// ============================================================
// Jenkinsfile — Multi-Workspace Databricks Pipeline
// FIX: Stage 4.5 now creates jobs directly via REST API
//      from Jenkins — no notebook run needed at all.
// ============================================================

pipeline {

    agent any

    parameters {

        choice(
            name: 'WORKSPACE',
            choices: [
                'ALL',
                'karthik_workspace',
                'MARAN_workspace',
                'user3_workspace'
            ],
            description: 'Select target workspace'
        )

        string(
            name: 'GROUP_ID',
            defaultValue: '',
            description: 'Enter GROUP_ID'
        )

        booleanParam(
            name: 'SYNC_GIT',
            defaultValue: true,
            description: 'Sync GitHub repo before execution'
        )

        booleanParam(
            name: 'CREATE_JOBS',
            defaultValue: true,
            description: 'Auto-create job if it does not exist'
        )

        booleanParam(
            name: 'WAIT_FOR_COMPLETION',
            defaultValue: true,
            description: 'Wait for Databricks job completion'
        )
    }

    environment {
        GITHUB_REPO   = 'https://github.com/ID-KARTHIKEYAN/DATA_INTEGRATION.git'
        GITHUB_BRANCH = 'main'
        POLL_INTERVAL = '15'
        MAX_WAIT_SECS = '1800'
    }

    stages {

        // ========================================================
        // STAGE 1 — VALIDATE
        // ========================================================

        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.GROUP_ID?.trim()) {
                        error "❌ GROUP_ID must not be empty"
                    }
                    echo """
==================================================
GROUP_ID            : ${params.GROUP_ID}
WORKSPACE           : ${params.WORKSPACE}
SYNC_GIT            : ${params.SYNC_GIT}
CREATE_JOBS         : ${params.CREATE_JOBS}
WAIT_FOR_COMPLETION : ${params.WAIT_FOR_COMPLETION}
==================================================
"""
                }
            }
        }

        // ========================================================
        // STAGE 2 — CHECKOUT REPO
        // ========================================================

        stage('Checkout Repo') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${env.GITHUB_BRANCH}"]],
                    userRemoteConfigs: [[url: env.GITHUB_REPO]]
                ])
                echo "✅ Repository checked out successfully"
            }
        }

        // ========================================================
        // STAGE 3 — LOAD WORKSPACE REGISTRY
        // ========================================================

        stage('Load Workspace Registry') {
            steps {
                script {
                    def registry = readJSON text: readFile('workspaces.json')

                    def selected = registry.workspaces.findAll { ws ->
                        ws.is_active &&
                        (params.WORKSPACE == 'ALL' || ws.name == params.WORKSPACE)
                    }

                    if (selected.isEmpty()) {
                        error "❌ No active workspaces found for: ${params.WORKSPACE}"
                    }

                    env.SELECTED_WORKSPACES = writeJSON(returnText: true, json: selected)

                    echo "✅ Selected workspaces:"
                    selected.each { echo "   - ${it.name}" }
                }
            }
        }

        // ========================================================
        // STAGE 4 — SYNC GIT REPOS
        // ========================================================

        stage('Sync Git Repos') {
            when { expression { return params.SYNC_GIT } }
            steps {
                script {
                    def workspaces = readJSON text: env.SELECTED_WORKSPACES

                    workspaces.each { ws ->

                        echo "🔄 Syncing : ${ws.name}"

                        withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {

                            // Get repo list
                            def repoResp = sh(
                                returnStdout: true,
                                script: """
                                    curl -s \
                                    -X GET '${ws.workspace_url}/api/2.0/repos' \
                                    -H 'Authorization: Bearer ${DB_TOKEN}'
                                """
                            ).trim()

                            def repos = readJSON text: repoResp
                            def repo  = repos.repos?.find { it.path == ws.github_repo_path }

                            if (!repo) {
                                echo "⚠️  Repo not found at: ${ws.github_repo_path} — skipping sync"
                                return
                            }

                            // Pull latest
                            def patchResp = sh(
                                returnStdout: true,
                                script: """
                                    curl -s -w "\\n%{http_code}" \
                                    -X PATCH '${ws.workspace_url}/api/2.0/repos/${repo.id}' \
                                    -H 'Authorization: Bearer ${DB_TOKEN}' \
                                    -H 'Content-Type: application/json' \
                                    -d '{"branch":"${env.GITHUB_BRANCH}"}'
                                """
                            ).trim()

                            def patchLines = patchResp.split('\n')
                            def httpCode   = patchLines[-1]

                            if (httpCode == '200') {
                                echo "✅ Git sync done : ${ws.name}"
                            } else {
                                echo "⚠️  Git sync HTTP ${httpCode} on ${ws.name} — continuing"
                            }
                        }
                    }
                }
            }
        }

        // ========================================================
        // STAGE 4.5 — CREATE JOB IF NOT EXISTS
        // No notebook, no serverless — pure REST API from Jenkins
        // ========================================================

        stage('Create / Verify Jobs') {
            when { expression { return params.CREATE_JOBS } }
            steps {
                script {
                    def workspaces  = readJSON text: env.SELECTED_WORKSPACES
                    def parallelMap = [:]

                    workspaces.each { ws ->

                        parallelMap[ws.name] = {

                            withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {

                                echo "=================================================="
                                echo "🛠️  Create/Verify Job : ${ws.name} | ${params.GROUP_ID}"
                                echo "=================================================="

                                // ── Step 1: List existing jobs ────────────────
                                def listResp = sh(
                                    returnStdout: true,
                                    script: """
                                        curl -s \
                                        -X GET '${ws.workspace_url}/api/2.1/jobs/list?limit=100' \
                                        -H 'Authorization: Bearer ${DB_TOKEN}'
                                    """
                                ).trim()

                                def listJson   = readJSON text: listResp
                                def existingJob = listJson.jobs?.find { j ->
                                    j.settings?.name == params.GROUP_ID
                                }

                                if (existingJob) {
                                    // Job already exists — use its id
                                    ws.job_id = existingJob.job_id
                                    echo "✅ Job already exists — job_id: ${ws.job_id}"

                                } else {
                                    // ── Step 2: Create job via REST API ───────
                                    echo "📦 Job not found — creating via API..."

                                    // Notebook path = repo path + /notebooks/run_framework
                                    def notebookPath = "${ws.github_repo_path}/notebooks/run_framework"

                                    def createResp = sh(
                                        returnStdout: true,
                                        script: """
                                            curl -s -w "\\n%{http_code}" \
                                            -X POST '${ws.workspace_url}/api/2.1/jobs/create' \
                                            -H 'Authorization: Bearer ${DB_TOKEN}' \
                                            -H 'Content-Type: application/json' \
                                            -d '{
                                              "name": "${params.GROUP_ID}",
                                              "max_concurrent_runs": 1,
                                              "parameters": [
                                                {"name": "GROUP_ID", "default": "${params.GROUP_ID}"}
                                              ],
                                              "tasks": [
                                                {
                                                  "task_key": "${params.GROUP_ID}_task",
                                                  "notebook_task": {
                                                    "notebook_path": "${notebookPath}",
                                                    "base_parameters": {
                                                      "GROUP_ID": "${params.GROUP_ID}"
                                                    },
                                                    "source": "WORKSPACE"
                                                  },
                                                  "environment_key": "default_env"
                                                }
                                              ],
                                              "environments": [
                                                {
                                                  "environment_key": "default_env",
                                                  "spec": {"client": "1"}
                                                }
                                              ]
                                            }'
                                        """
                                    ).trim()

                                    def createLines  = createResp.split('\n')
                                    def createCode   = createLines[-1]
                                    def createBody   = createLines[0..-2].join('\n')

                                    if (createCode != '200') {
                                        error "❌ Job creation failed on ${ws.name}\nHTTP ${createCode}\n${createBody}"
                                    }

                                    def createJson = readJSON text: createBody
                                    ws.job_id      = createJson.job_id

                                    echo "✅ Job created — job_id: ${ws.job_id}"
                                }
                            }
                        }
                    }

                    parallel parallelMap

                    // Save updated job_ids for Stage 5
                    env.SELECTED_WORKSPACES = writeJSON(returnText: true, json: workspaces)
                }
            }
        }

        // ========================================================
        // STAGE 5 — TRIGGER DATABRICKS JOBS
        // ========================================================

        stage('Trigger Databricks Jobs') {
            steps {
                script {
                    def workspaces  = readJSON text: env.SELECTED_WORKSPACES
                    def parallelMap = [:]
                    def runIds      = [:]

                    workspaces.each { ws ->

                        parallelMap[ws.name] = {

                            withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {

                                echo "🚀 Triggering | ${ws.name} | job_id: ${ws.job_id}"

                                def trigResp = sh(
                                    returnStdout: true,
                                    script: """
                                        curl -s -w "\\n%{http_code}" \
                                        -X POST '${ws.workspace_url}/api/2.1/jobs/run-now' \
                                        -H 'Authorization: Bearer ${DB_TOKEN}' \
                                        -H 'Content-Type: application/json' \
                                        -d '{
                                          "job_id": ${ws.job_id},
                                          "job_parameters": {
                                            "GROUP_ID": "${params.GROUP_ID}"
                                          }
                                        }'
                                    """
                                ).trim()

                                def lines    = trigResp.split('\n')
                                def httpCode = lines[-1]
                                def body     = lines[0..-2].join('\n')

                                if (httpCode != '200') {
                                    error "❌ Trigger failed on ${ws.name}\nHTTP ${httpCode}\n${body}"
                                }

                                def trigJson = readJSON text: body
                                def runId    = trigJson.run_id
                                echo "✅ Triggered — run_id: ${runId}"

                                runIds[ws.name] = [
                                    run_id       : runId,
                                    workspace_url: ws.workspace_url,
                                    credential_id: ws.credential_id
                                ]
                            }
                        }
                    }

                    parallel parallelMap
                    env.RUN_IDS = writeJSON(returnText: true, json: runIds)
                }
            }
        }

        // ========================================================
        // STAGE 6 — WAIT FOR COMPLETION
        // ========================================================

        stage('Wait For Completion') {
            when { expression { return params.WAIT_FOR_COMPLETION } }
            steps {
                script {
                    def runIds     = readJSON text: env.RUN_IDS
                    def allPassed  = true
                    def failedList = []

                    runIds.each { wsName, info ->

                        echo "⏳ Polling : ${wsName}"

                        withCredentials([string(credentialsId: info.credential_id, variable: 'DB_TOKEN')]) {

                            def elapsed = 0
                            def done    = false
                            def lcState = ''
                            def rsState = ''

                            while (!done && elapsed < Integer.parseInt(env.MAX_WAIT_SECS)) {

                                sleep(Integer.parseInt(env.POLL_INTERVAL))
                                elapsed += Integer.parseInt(env.POLL_INTERVAL)

                                def pollResp = sh(
                                    returnStdout: true,
                                    script: """
                                        curl -s \
                                        -X GET '${info.workspace_url}/api/2.1/jobs/runs/get?run_id=${info.run_id}' \
                                        -H 'Authorization: Bearer ${DB_TOKEN}'
                                    """
                                ).trim()

                                def state = (readJSON text: pollResp).state
                                lcState   = state?.life_cycle_state ?: 'UNKNOWN'
                                rsState   = state?.result_state     ?: ''

                                echo "   ${wsName} | ${lcState} | ${rsState}"

                                if (['TERMINATED','SKIPPED','INTERNAL_ERROR'].contains(lcState)) {
                                    done = true
                                }
                            }

                            if (!done) {
                                failedList << "${wsName} (TIMEOUT)"
                                allPassed = false
                            } else if (rsState != 'SUCCESS') {
                                failedList << "${wsName} (${rsState})"
                                allPassed = false
                            } else {
                                echo "✅ ${wsName} — SUCCESS"
                            }
                        }
                    }

                    if (!allPassed) {
                        error "❌ Failed: ${failedList.join(', ')}"
                    }

                    echo "🎉 All workspaces completed successfully"
                }
            }
        }
    }

    post {
        always {
            echo """
╔══════════════════════════════════════════════╗
║              PIPELINE SUMMARY               ║
╠══════════════════════════════════════════════╣
║ GROUP_ID    : ${params.GROUP_ID}
║ WORKSPACE   : ${params.WORKSPACE}
║ CREATE_JOBS : ${params.CREATE_JOBS}
║ STATUS      : ${currentBuild.currentResult}
╚══════════════════════════════════════════════╝
"""
        }
        success { echo "✅ PIPELINE SUCCESS" }
        failure { echo "❌ PIPELINE FAILED" }
    }
}
