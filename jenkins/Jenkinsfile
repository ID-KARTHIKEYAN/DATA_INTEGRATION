// ============================================================
// Jenkinsfile — Multi-Workspace Databricks Pipeline
// ============================================================

pipeline {

    agent any

    parameters {
        string(name: 'GROUP_ID',   defaultValue: '', description: 'e.g. FINANCE_MEDALLION_L0')
        string(name: 'BUNDLE_TAG', defaultValue: '', description: 'Release tag e.g. v1.0.0')
        string(name: 'VERSION',    defaultValue: '1.0', description: 'Pipeline version')
        booleanParam(name: 'SYNC_GIT',            defaultValue: true,  description: 'Sync GitHub repo')
        booleanParam(name: 'SYNC_TABLES_TO_GITHUB', defaultValue: true, description: 'Push SQL to META_STORE_SQL_SCRIPTS/')
        booleanParam(name: 'CREATE_JOBS',          defaultValue: true,  description: 'Create/verify Databricks jobs')
        booleanParam(name: 'WAIT_FOR_COMPLETION',  defaultValue: true,  description: 'Wait for job completion')
    }

    environment {
        GITHUB_REPO          = 'https://github.com/ID-KARTHIKEYAN/DATA_INTEGRATION.git'
        GITHUB_API           = 'https://api.github.com'
        GITHUB_OWNER         = 'ID-KARTHIKEYAN'
        GITHUB_REPO_NAME     = 'DATA_INTEGRATION'
        GITHUB_BRANCH        = 'main'
        GITHUB_CREDENTIAL_ID = 'GITHUB_TOKEN_SECRET'
        SQL_SCRIPTS_FOLDER   = 'META_STORE_SQL_SCRIPTS'
        POLL_INTERVAL        = '15'
        MAX_WAIT_SECS        = '1800'
    }

    stages {

        // ── STAGE 1 : VALIDATE ───────────────────────────────
        stage('Validate') {
            steps {
                script {
                    if (!params.GROUP_ID?.trim()) error "GROUP_ID required"
                    def gid = params.GROUP_ID.trim().toUpperCase()
                    def layer = gid.endsWith('_L0') ? 'L0' : gid.endsWith('_L1') ? 'L1' : gid.endsWith('_L2') ? 'L2' : 'ALL'
                    def ts    = new Date().format('yyyy-MM-dd HH:mm')
                    def tag   = params.BUNDLE_TAG?.trim() ?: 'untagged'
                    env.DETECTED_LAYER = layer
                    env.DEPLOY_TS      = ts
                    env.BUNDLE_INFO    = "[v${params.VERSION}][${tag}] ${ts} | ${layer} | ${env.GITHUB_BRANCH}"
                    echo "GROUP_ID=${gid} | LAYER=${layer} | BUNDLE=${tag} | ${ts}"
                }
            }
        }

        // ── STAGE 2 : CHECKOUT ──────────────────────────────
        stage('Checkout') {
            steps {
                checkout([$class:'GitSCM', branches:[[name:"*/${env.GITHUB_BRANCH}"]], userRemoteConfigs:[[url:env.GITHUB_REPO]]])
                echo "Checked out ${env.GITHUB_BRANCH}"
            }
        }

        // ── STAGE 3 : LOAD REGISTRY (auto-detects workspace) ──
        // No manual WORKSPACE selection needed.
        // Jenkins username → matched EXACTLY to jenkins_user in workspaces.json
        // Each user only gets their own workspace — no fallback to all workspaces.
        // Admin override: set WORKSPACE_OVERRIDE parameter to a specific workspace name.
        stage('Load Registry') {
            steps {
                script {
                    // ── Get Jenkins username who clicked Build ────────────
                    // Requires Build User Vars plugin to be installed.
                    // Manage Jenkins → Plugins → search "Build User Vars Plugin"
                    def buildUser = currentBuild
                        .getBuildCauses('hudson.model.Cause$UserIdCause')
                        .collect { it?.userId }
                        .find { it }
                        ?: env.BUILD_USER_ID
                        ?: 'UNKNOWN'

                    echo "================================================"
                    echo "  Build triggered by : ${buildUser}"
                    echo "================================================"

                    def wsRaw = readFile('workspaces.json')
                    def reg   = readJSON text: wsRaw

                    def sel = []

                    if (params.WORKSPACE_OVERRIDE?.trim()) {
                        // ── Admin override: specific workspace by name ────
                        sel = reg.workspaces.findAll { ws ->
                            ws.is_active == true &&
                            !ws._template &&
                            ws.name == params.WORKSPACE_OVERRIDE.trim()
                        }
                        if (sel.isEmpty()) {
                            error (
                                "WORKSPACE_OVERRIDE '${params.WORKSPACE_OVERRIDE}' not found.\n" +
                                "Check workspace name in workspaces.json."
                            )
                        }
                        echo "  Mode : ADMIN OVERRIDE → ${params.WORKSPACE_OVERRIDE}"

                    } else {
                        // ── Auto-detect: strict match on jenkins_user field ───
                        // ONLY the workspace that belongs to this user is selected.
                        // No fallback to all workspaces — prevents cross-deployment.
                        sel = reg.workspaces.findAll { ws ->
                            ws.is_active == true &&
                            !ws._template &&
                            ws.jenkins_user == buildUser
                        }

                        if (sel.isEmpty()) {
                            error (
                                "No workspace mapped to Jenkins user '${buildUser}'.\n" +
                                "Fix: go to workspaces.json and add jenkins_user='${buildUser}' \n" +
                                "     to your workspace entry, then push to GitHub.\n" +
                                "Admin: run WORKSPACE-MANAGEMENT-PIPELINE with ACTION=ADD to register."
                            )
                        }
                        echo "  Mode : AUTO-DETECT → matched jenkins_user='${buildUser}'"
                    }

                    env.SELECTED_WORKSPACES = writeJSON(returnText: true, json: sel)
                    env.BUILD_USER_RESOLVED = buildUser

                    echo "  Workspace(s) selected:"
                    sel.each { ws ->
                        echo "    ✅  ${ws.name} | ${ws.owner} | ${ws.workspace_url}"
                    }
                }
            }
        }

        // ── STAGE 4 : SYNC GIT ──────────────────────────────
        stage('Sync Git') {
            when { expression { params.SYNC_GIT } }
            steps {
                script {
                    def wsList = readJSON text: env.SELECTED_WORKSPACES
                    wsList.each { ws ->
                        withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {
                            def r    = readJSON text: sh(returnStdout:true, script:"curl -s '${ws.workspace_url}/api/2.0/repos' -H 'Authorization: Bearer ${DB_TOKEN}'").trim()
                            def repo = r.repos?.find { it.path == ws.github_repo_path }
                            if (!repo) { echo "  ${ws.name}: repo not found — skipping"; return }
                            def code = sh(returnStdout:true, script:"""
                                curl -s -w "\\n%{http_code}" -X PATCH '${ws.workspace_url}/api/2.0/repos/${repo.id}' \\
                                -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' \\
                                -d '{"branch":"${env.GITHUB_BRANCH}"}'
                            """).trim().split('\n')[-1]
                            echo "  ${ws.name}: sync HTTP ${code}"
                        }
                    }
                }
            }
        }

        // ── STAGE 4a : COLLECT SQL FROM CONTROL TABLES ──────
        stage('Collect SQL') {
            when { expression { params.SYNC_TABLES_TO_GITHUB } }
            steps {
                script {
                    def wsList  = readJSON text: env.SELECTED_WORKSPACES
                    def gid     = params.GROUP_ID.trim().toUpperCase()
                    def lines   = []

                    wsList.each { ws ->
                        withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {
                            def cat = ws.catalog ?: 'demo_catalog'
                            def whRaw = sh(returnStdout:true, script:"curl -s '${ws.workspace_url}/api/2.0/sql/warehouses' -H 'Authorization: Bearer ${DB_TOKEN}'").trim()
                            def whJson = readJSON text: whRaw
                            if ((whJson.warehouses ?: []).isEmpty()) { echo "  ${ws.name}: no warehouse"; return }
                            def whId = whJson.warehouses[0].id

                            def runQ = { String sql ->
                                def p   = writeJSON(returnText:true, json:[statement:sql, warehouse_id:whId, wait_timeout:'50s', on_wait_timeout:'CANCEL'])
                                def tmp = "/tmp/sq_${System.currentTimeMillis()}.json"
                                writeFile file:tmp, text:p
                                def raw = sh(returnStdout:true, script:"curl -s -w \"\n%{http_code}\" -X POST '${ws.workspace_url}/api/2.0/sql/statements' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${tmp}").trim()
                                sh "rm -f ${tmp}"
                                def ls = raw.split('\n')
                                if (ls[-1] != '200') return []
                                def j = readJSON text: ls[0..-2].join('\n')
                                return j.result?.data_array ?: []
                            }

                            def hdr = runQ("SELECT DATA_FLOW_GROUP_ID,NOTEBOOK_PATH FROM ${cat}.admin.data_flow_control_header WHERE DATA_FLOW_GROUP_ID='${gid}' AND IS_ACTIVE='Y'")
                            if (hdr.isEmpty()) { echo "  ${ws.name}: no header — skipping"; return }

                            def l0 = runQ("SELECT SOURCE_URL,SOURCE_OBJ_SCHEMA,SOURCE_OBJ_NAME,TARGET_SCHEMA,TARGET_TABLE,FILE_FORMAT,INPUT_FILE_FORMAT,LOAD_TYPE,DELIMETER FROM ${cat}.admin.data_flow_l0_detail WHERE DATA_FLOW_GROUP_ID='${gid}' AND IS_ACTIVE='Y'")
                            def l1 = runQ("SELECT SOURCE_OBJ_SCHEMA,SOURCE_OBJ_NAME,TARGET_SCHEMA,TARGET_TABLE,LOAD_TYPE,TRANSFORMATION_QUERY,MERGE_KEYS,PARTITION_BY FROM ${cat}.admin.data_flow_l1_detail WHERE DATA_FLOW_GROUP_ID='${gid}' AND IS_ACTIVE='Y'")
                            def l2 = runQ("SELECT SOURCE_OBJ_SCHEMA,SOURCE_OBJ_NAME,TARGET_SCHEMA,TARGET_TABLE,LOAD_TYPE,TRANSFORMATION_QUERY,MERGE_KEYS,PARTITION_BY FROM ${cat}.admin.data_flow_l2_detail WHERE DATA_FLOW_GROUP_ID='${gid}' AND IS_ACTIVE='Y'")

                            if (l0.isEmpty() && l1.isEmpty() && l2.isEmpty()) { echo "  ${ws.name}: no rows — skipping"; return }

                            def np = hdr[0][1]
                            def ts = new Date().format('yyyy-MM-dd HH:mm:ss')

                            lines << "-- ============================================================"
                            lines << "-- Workspace : ${ws.name}  |  GROUP_ID : ${gid}"
                            lines << "-- Layers    : L0(${l0.size()}) L1(${l1.size()}) L2(${l2.size()})  Generated: ${ts}"
                            lines << "-- ============================================================"
                            lines << ""
                            lines << "MERGE INTO ${cat}.admin.data_flow_control_header AS tgt USING (SELECT '${gid}' AS DATA_FLOW_GROUP_ID,'${gid}_JOB' AS JOB_NAME,'${np}' AS NOTEBOOK_PATH,'Y' AS IS_ACTIVE,current_timestamp() AS CREATED_DATE,current_timestamp() AS UPDATED_DATE) AS src ON tgt.DATA_FLOW_GROUP_ID=src.DATA_FLOW_GROUP_ID WHEN MATCHED THEN UPDATE SET tgt.NOTEBOOK_PATH=src.NOTEBOOK_PATH,tgt.IS_ACTIVE=src.IS_ACTIVE,tgt.UPDATED_DATE=src.UPDATED_DATE WHEN NOT MATCHED THEN INSERT *;"
                            lines << ""

                            if (!l0.isEmpty()) {
                                lines << "-- L0 Bronze"
                                l0.each { r -> lines << "MERGE INTO ${cat}.admin.data_flow_l0_detail AS tgt USING (SELECT '${gid}' AS DATA_FLOW_GROUP_ID,'${r[0]}' AS SOURCE_URL,'${r[1]}' AS SOURCE_OBJ_SCHEMA,'${r[2]}' AS SOURCE_OBJ_NAME,'${r[3]}' AS TARGET_SCHEMA,'${r[4]}' AS TARGET_TABLE,'${r[5]}' AS FILE_FORMAT,'${r[6]?:r[5]}' AS INPUT_FILE_FORMAT,'${r[7]}' AS LOAD_TYPE,'${r[8]?:','}' AS DELIMETER,'Y' AS IS_ACTIVE,current_timestamp() AS CREATED_DATE,current_timestamp() AS UPDATED_DATE) AS src ON tgt.DATA_FLOW_GROUP_ID=src.DATA_FLOW_GROUP_ID AND tgt.TARGET_TABLE=src.TARGET_TABLE WHEN MATCHED THEN UPDATE SET tgt.SOURCE_URL=src.SOURCE_URL,tgt.FILE_FORMAT=src.FILE_FORMAT,tgt.LOAD_TYPE=src.LOAD_TYPE,tgt.IS_ACTIVE=src.IS_ACTIVE,tgt.UPDATED_DATE=src.UPDATED_DATE WHEN NOT MATCHED THEN INSERT *;" }
                                lines << ""
                            }

                            if (!l1.isEmpty()) {
                                lines << "-- L1 Silver"
                                l1.each { r -> def tq=(r[5]?:"").toString().replace("'","''"); lines << "MERGE INTO ${cat}.admin.data_flow_l1_detail AS tgt USING (SELECT '${gid}' AS DATA_FLOW_GROUP_ID,'${r[0]}' AS SOURCE_OBJ_SCHEMA,'${r[1]}' AS SOURCE_OBJ_NAME,'${r[2]}' AS TARGET_SCHEMA,'${r[3]}' AS TARGET_TABLE,'${r[4]}' AS LOAD_TYPE,'${tq}' AS TRANSFORMATION_QUERY,'${r[6]?:""}' AS MERGE_KEYS,'${r[7]?:""}' AS PARTITION_BY,'Y' AS IS_ACTIVE,current_timestamp() AS CREATED_DATE,current_timestamp() AS UPDATED_DATE) AS src ON tgt.DATA_FLOW_GROUP_ID=src.DATA_FLOW_GROUP_ID AND tgt.TARGET_TABLE=src.TARGET_TABLE WHEN MATCHED THEN UPDATE SET tgt.TRANSFORMATION_QUERY=src.TRANSFORMATION_QUERY,tgt.LOAD_TYPE=src.LOAD_TYPE,tgt.IS_ACTIVE=src.IS_ACTIVE,tgt.UPDATED_DATE=src.UPDATED_DATE WHEN NOT MATCHED THEN INSERT *;" }
                                lines << ""
                            }

                            if (!l2.isEmpty()) {
                                lines << "-- L2 Gold"
                                l2.each { r -> def tq=(r[5]?:"").toString().replace("'","''"); lines << "MERGE INTO ${cat}.admin.data_flow_l2_detail AS tgt USING (SELECT '${gid}' AS DATA_FLOW_GROUP_ID,'${r[0]}' AS SOURCE_OBJ_SCHEMA,'${r[1]}' AS SOURCE_OBJ_NAME,'${r[2]}' AS TARGET_SCHEMA,'${r[3]}' AS TARGET_TABLE,'${r[4]}' AS LOAD_TYPE,'${tq}' AS TRANSFORMATION_QUERY,'${r[6]?:""}' AS MERGE_KEYS,'${r[7]?:""}' AS PARTITION_BY,'Y' AS IS_ACTIVE,current_timestamp() AS CREATED_DATE,current_timestamp() AS UPDATED_DATE) AS src ON tgt.DATA_FLOW_GROUP_ID=src.DATA_FLOW_GROUP_ID AND tgt.TARGET_TABLE=src.TARGET_TABLE WHEN MATCHED THEN UPDATE SET tgt.TRANSFORMATION_QUERY=src.TRANSFORMATION_QUERY,tgt.LOAD_TYPE=src.LOAD_TYPE,tgt.IS_ACTIVE=src.IS_ACTIVE,tgt.UPDATED_DATE=src.UPDATED_DATE WHEN NOT MATCHED THEN INSERT *;" }
                                lines << ""
                            }

                            echo "  ${ws.name}: L0=${l0.size()} L1=${l1.size()} L2=${l2.size()} collected"
                        }
                    }

                    if (lines.isEmpty()) { echo "Nothing to push"; return }
                    def sqlTmp = "/tmp/${params.GROUP_ID.trim().toUpperCase()}_content.txt"
                    writeFile file: sqlTmp, text: lines.join('\n')
                    env.SQL_TMP_FILE  = sqlTmp
                    env.SQL_FILE_NAME = "${env.SQL_SCRIPTS_FOLDER}/${params.GROUP_ID.trim().toUpperCase()}.sql"
                }
            }
        }

        // ── STAGE 4b : PUSH SQL TO GITHUB ────────────────────
        stage('Push SQL to GitHub') {
            when { expression { params.SYNC_TABLES_TO_GITHUB && env.SQL_TMP_FILE?.trim() } }
            steps {
                script {
                    def gid     = params.GROUP_ID.trim().toUpperCase()
                    def sqlFile = env.SQL_FILE_NAME
                    def b64     = sh(returnStdout:true, script:"base64 -w 0 ${env.SQL_TMP_FILE}").trim()
                    sh "rm -f ${env.SQL_TMP_FILE}"

                    withCredentials([string(credentialsId: env.GITHUB_CREDENTIAL_ID, variable: 'GH_TOKEN')]) {
                        def chkRaw   = sh(returnStdout:true, script:"curl -s -w \"\n%{http_code}\" -X GET '${env.GITHUB_API}/repos/${env.GITHUB_OWNER}/${env.GITHUB_REPO_NAME}/contents/${sqlFile}?ref=${env.GITHUB_BRANCH}' -H 'Authorization: Bearer ${GH_TOKEN}'").trim()
                        def chkLines = chkRaw.split('\n')
                        def payload  = [message:"sync: ${gid}.sql [Jenkins]", content:b64, branch:env.GITHUB_BRANCH]
                        if (chkLines[-1] == '200') {
                            def shaJson = readJSON text: chkLines[0..-2].join('\n')
                            payload.sha = shaJson.sha
                        }
                        def pTmp = "/tmp/ghpush_${System.currentTimeMillis()}.json"
                        writeFile file: pTmp, text: writeJSON(returnText:true, json:payload)
                        def code = sh(returnStdout:true, script:"curl -s -w \"\n%{http_code}\" -X PUT '${env.GITHUB_API}/repos/${env.GITHUB_OWNER}/${env.GITHUB_REPO_NAME}/contents/${sqlFile}' -H 'Authorization: Bearer ${GH_TOKEN}' -H 'Content-Type: application/json' -d @${pTmp}").trim().split('\n')[-1]
                        sh "rm -f ${pTmp}"
                        echo code in ['200','201'] ? "✅ ${sqlFile} pushed to GitHub" : "❌ push HTTP ${code}"
                    }
                }
            }
        }

        // ── STAGE 5a : QUERY CONTROL TABLE ──────────────────
        // Separate from job creation to reduce method size
        stage('Load Table Config') {
            when { expression { params.CREATE_JOBS } }
            steps {
                script {
                    def wsList  = readJSON text: env.SELECTED_WORKSPACES
                    def groupId = params.GROUP_ID.trim().toUpperCase()
                    def layer   = env.DETECTED_LAYER
                    def tableMap = [:]   // wsName → list of [TARGET_TABLE, TARGET_SCHEMA]

                    wsList.each { ws ->
                        withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {
                            def catalog = ws.catalog ?: 'demo_catalog'
                            def wh = readJSON text: sh(returnStdout:true, script:"curl -s '${ws.workspace_url}/api/2.0/sql/warehouses' -H 'Authorization: Bearer ${DB_TOKEN}'").trim()
                            if ((wh.warehouses ?: []).isEmpty()) { echo "  ${ws.name}: no warehouse"; tableMap[ws.name] = []; return }
                            def whId = wh.warehouses[0].id

                            def detail = layer == 'L1' ? 'data_flow_l1_detail' : layer == 'L2' ? 'data_flow_l2_detail' : 'data_flow_l0_detail'
                            def sql    = "SELECT TARGET_TABLE, TARGET_SCHEMA FROM ${catalog}.admin.${detail} WHERE DATA_FLOW_GROUP_ID='${groupId}' AND IS_ACTIVE='Y' AND UPPER(LOAD_TYPE)!='VIEW' ORDER BY TARGET_TABLE"
                            def p      = writeJSON(returnText:true, json:[statement:sql, warehouse_id:whId, wait_timeout:'50s', on_wait_timeout:'CANCEL'])
                            def tmp    = "/tmp/tbl_${System.currentTimeMillis()}.json"
                            writeFile file: tmp, text: p
                            def raw  = sh(returnStdout:true, script:"curl -s -w \"\\n%{http_code}\" -X POST '${ws.workspace_url}/api/2.0/sql/statements' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${tmp}").trim()
                            sh "rm -f ${tmp}"
                            def lines = raw.split('\n')
                            def rowBody = lines[0..-2].join('\n')
                                    def rowJson = lines[-1] == '200' ? readJSON(text: rowBody) : [:]
                                    def rows    = rowJson.result?.data_array ?: []
                            tableMap[ws.name] = rows
                            echo "  ${ws.name}: ${rows.size()} table(s) in ${detail}"
                            rows.each { r -> echo "    → ${r[1]}.${r[0]}" }
                        }
                    }
                    env.TABLE_MAP = writeJSON(returnText:true, json:tableMap)
                }
            }
        }

        // ── STAGE 5b : CREATE / VERIFY JOBS ─────────────────
        stage('Create Jobs') {
            when { expression { params.CREATE_JOBS } }
            steps {
                script {
                    def wsList      = readJSON text: env.SELECTED_WORKSPACES
                    def tableMap    = readJSON text: env.TABLE_MAP
                    def groupId     = params.GROUP_ID.trim().toUpperCase()
                    def tag         = params.BUNDLE_TAG?.trim() ?: 'untagged'
                    def parallelMap = [:]

                    wsList.each { ws ->
                        def wsLocal = ws
                        parallelMap[wsLocal.name] = {
                            withCredentials([string(credentialsId: wsLocal.credential_id, variable: 'DB_TOKEN')]) {
                                def jobName    = "DBX_${groupId}_JOB"
                                def nbPath     = "${wsLocal.github_repo_path}/notebooks/run_framework"
                                def tableRows  = tableMap[wsLocal.name] ?: []
                                def expTasks   = tableRows.isEmpty() ? 1 : tableRows.size()

                                // Check existing job
                                def listJson   = readJSON text: sh(returnStdout:true, script:"curl -s '${wsLocal.workspace_url}/api/2.1/jobs/list?limit=100' -H 'Authorization: Bearer ${DB_TOKEN}'").trim()
                                def existing   = listJson.jobs?.find { it.settings?.name == jobName }

                                if (existing) {
                                    def curTasks = existing.settings?.tasks?.size() ?: 1
                                    if (curTasks == expTasks) {
                                        wsLocal.job_id = existing.job_id
                                        echo "  ${jobName} ✅ exists | tasks=${curTasks}"
                                    } else {
                                        // Delete stale job
                                        def dt = writeJSON(returnText:true, json:[job_id: existing.job_id])
                                        def df = "/tmp/del_${System.currentTimeMillis()}.json"
                                        writeFile file: df, text: dt
                                        sh "curl -s -X POST '${wsLocal.workspace_url}/api/2.1/jobs/delete' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${df}"
                                        sh "rm -f ${df}"
                                        echo "  ${jobName} outdated (${curTasks}→${expTasks} tasks) — deleted"
                                        existing = null
                                    }
                                }

                                if (!existing) {
                                    // Build tasks list — one per table
                                    def tasks = tableRows.isEmpty()
                                        ? [[task_key:"${groupId}_task", notebook_task:[notebook_path:nbPath, base_parameters:[GROUP_ID:groupId, TARGET_LOAD_TABLE:'ALL', ENVIRONMENT:tag], source:'WORKSPACE']]]
                                        : tableRows.collect { r ->
                                            def tbl = r[0]
                                            [task_key: tbl.replaceAll('[^a-zA-Z0-9_]','_'),
                                             notebook_task:[notebook_path:nbPath, base_parameters:[GROUP_ID:groupId, TARGET_LOAD_TABLE:tbl, ENVIRONMENT:tag], source:'WORKSPACE']]
                                          }

                                    def jp  = writeJSON(returnText:true, json:[
                                        name:jobName, description:"GROUP_ID:${groupId}|Layer:${env.DETECTED_LAYER}|Bundle:${tag}|${env.DEPLOY_TS}",
                                        max_concurrent_runs:1,
                                        parameters:[[name:'GROUP_ID',default:groupId],[name:'ENVIRONMENT',default:tag]],
                                        tasks:tasks
                                    ])
                                    def jf  = "/tmp/job_${System.currentTimeMillis()}.json"
                                    writeFile file:jf, text:jp
                                    def raw = sh(returnStdout:true, script:"curl -s -w \"\\n%{http_code}\" -X POST '${wsLocal.workspace_url}/api/2.1/jobs/create' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${jf}").trim()
                                    sh "rm -f ${jf}"
                                    def lines = raw.split('\n')
                                    if (lines[-1] != '200') error "Job create failed HTTP ${lines[-1]}: ${lines[0..-2].join('\n')}"
                                    def cjson = readJSON text: lines[0..-2].join('\n')
                                    wsLocal.job_id = cjson.job_id
                                    echo "  ${jobName} created | job_id=${wsLocal.job_id} | tasks=${tasks.size()}"
                                    tasks.each { t -> echo "    task: ${t.task_key} → ${t.notebook_task.base_parameters.TARGET_LOAD_TABLE ?: '(all)'}" }
                                }
                            }
                        }
                    }
                    parallel parallelMap
                    env.SELECTED_WORKSPACES = writeJSON(returnText:true, json:wsList)
                }
            }
        }

        // ── STAGE 6 : TRIGGER ───────────────────────────────
        stage('Trigger Jobs') {
            steps {
                script {
                    def wsList  = readJSON text: env.SELECTED_WORKSPACES
                    def groupId = params.GROUP_ID.trim().toUpperCase()
                    def runIds  = [:]
                    def pMap    = [:]

                    wsList.each { ws ->
                        pMap[ws.name] = {
                            withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {
                                def tp  = writeJSON(returnText:true, json:[job_id:ws.job_id, job_parameters:[GROUP_ID:groupId, RUN_LAYER:env.DETECTED_LAYER]])
                                def tf  = "/tmp/trig_${System.currentTimeMillis()}.json"
                                writeFile file:tf, text:tp
                                def raw = sh(returnStdout:true, script:"curl -s -w \"\\n%{http_code}\" -X POST '${ws.workspace_url}/api/2.1/jobs/run-now' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${tf}").trim()
                                sh "rm -f ${tf}"
                                def lines = raw.split('\n')
                                if (lines[-1] != '200') error "Trigger failed HTTP ${lines[-1]}: ${lines[0..-2].join('\n')}"
                                def rjson = readJSON text: lines[0..-2].join('\n')
                                def runId = rjson.run_id
                                runIds[ws.name] = [run_id:runId, workspace_url:ws.workspace_url, credential_id:ws.credential_id]
                                echo "  ${ws.name} triggered | run_id=${runId}"
                            }
                        }
                    }
                    parallel pMap
                    env.RUN_IDS = writeJSON(returnText:true, json:runIds)
                }
            }
        }

        // ── STAGE 7 : WAIT ──────────────────────────────────
        stage('Wait For Completion') {
            when { expression { params.WAIT_FOR_COMPLETION } }
            steps {
                script {
                    def runIds     = readJSON text: env.RUN_IDS
                    def allPassed  = true
                    def failedList = []

                    runIds.each { wsName, info ->
                        withCredentials([string(credentialsId: info.credential_id, variable: 'DB_TOKEN')]) {
                            def elapsed = 0
                            def done    = false
                            def lc = ''; def rs = ''
                            while (!done && elapsed < Integer.parseInt(env.MAX_WAIT_SECS)) {
                                sleep(Integer.parseInt(env.POLL_INTERVAL))
                                elapsed += Integer.parseInt(env.POLL_INTERVAL)
                                def p    = readJSON text: sh(returnStdout:true, script:"curl -s '${info.workspace_url}/api/2.1/jobs/runs/get?run_id=${info.run_id}' -H 'Authorization: Bearer ${DB_TOKEN}'").trim()
                                lc       = p.state?.life_cycle_state ?: 'UNKNOWN'
                                rs       = p.state?.result_state     ?: ''
                                echo "${wsName} | ${lc} | ${rs}"
                                if (['TERMINATED','SKIPPED','INTERNAL_ERROR'].contains(lc)) done = true
                            }
                            if (!done)        { failedList << "${wsName}(TIMEOUT)"; allPassed = false }
                            else if (rs != 'SUCCESS') { failedList << "${wsName}(${rs})"; allPassed = false }
                            else echo "${wsName} — SUCCESS"
                        }
                    }
                    if (!allPassed) error "Failed: ${failedList.join(', ')}"
                    echo "All workspaces complete"
                }
            }
        }

        // ── STAGE 8 : TRIGGER VIEW PIPELINE ─────────────────
        stage('Trigger View Pipeline') {
            when { expression { currentBuild.currentResult == 'SUCCESS' } }
            steps {
                script {
                    def wsList  = readJSON text: env.SELECTED_WORKSPACES
                    def groupId = params.GROUP_ID.trim().toUpperCase()
                    def pMap    = [:]

                    wsList.each { ws ->
                        def wsLocal = ws
                        pMap[wsLocal.name] = {
                            withCredentials([string(credentialsId: wsLocal.credential_id, variable: 'DB_TOKEN')]) {
                                def catalog = wsLocal.catalog ?: 'demo_catalog'
                                def wh = readJSON text: sh(returnStdout:true, script:"curl -s '${wsLocal.workspace_url}/api/2.0/sql/warehouses' -H 'Authorization: Bearer ${DB_TOKEN}'").trim()
                                if ((wh.warehouses ?: []).isEmpty()) { echo "  ${wsLocal.name}: no warehouse — skip"; return }
                                def whId = wh.warehouses[0].id

                                def runQ = { String sql ->
                                    def p   = writeJSON(returnText:true, json:[statement:sql, warehouse_id:whId, wait_timeout:'50s', on_wait_timeout:'CANCEL'])
                                    def tmp = "/tmp/vq_${System.currentTimeMillis()}.json"
                                    writeFile file:tmp, text:p
                                    def raw = sh(returnStdout:true, script:"curl -s -w \"\\n%{http_code}\" -X POST '${wsLocal.workspace_url}/api/2.0/sql/statements' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${tmp}").trim()
                                    sh "rm -f ${tmp}"
                                    def lines = raw.split('\n')
                                    if (lines[-1] != '200') return []
                                    def j = readJSON text: lines[0..-2].join('\n')
                                    return j.result?.data_array ?: []
                                }

                                def l1 = runQ("SELECT COUNT(*),MAX(TARGET_SCHEMA) FROM ${catalog}.admin.data_flow_l1_detail WHERE DATA_FLOW_GROUP_ID='${groupId}' AND IS_ACTIVE='Y' AND UPPER(LOAD_TYPE)='VIEW'")
                                def l2 = runQ("SELECT COUNT(*),MAX(TARGET_SCHEMA) FROM ${catalog}.admin.data_flow_l2_detail WHERE DATA_FLOW_GROUP_ID='${groupId}' AND IS_ACTIVE='Y' AND UPPER(LOAD_TYPE)='VIEW'")
                                def l1c = l1 ? (l1[0][0] as int) : 0
                                def l2c = l2 ? (l2[0][0] as int) : 0
                                def total = l1c + l2c

                                echo "  ${wsLocal.name}: VIEW rows L1=${l1c} L2=${l2c}"
                                if (total == 0) { echo "  No VIEW rows — skip"; return }

                                def vLayer  = (l1c > 0 && l2c == 0) ? 'L1' : (l2c > 0 && l1c == 0) ? 'L2' : 'ALL'
                                def tSchema = (l1c > 0 ? l1[0][1] : null) ?: (l2c > 0 ? l2[0][1] : null) ?: 'silver'
                                def vJob    = "DBX_${groupId}_VIEW_JOB"
                                def vPath   = "${wsLocal.github_repo_path}/notebooks/view_pipeline"

                                def listJ  = readJSON text: sh(returnStdout:true, script:"curl -s '${wsLocal.workspace_url}/api/2.1/jobs/list?limit=100' -H 'Authorization: Bearer ${DB_TOKEN}'").trim()
                                def existV = listJ.jobs?.find { it.settings?.name == vJob }
                                def vJobId

                                if (existV) {
                                    vJobId = existV.job_id
                                    echo "  View job exists: ${vJobId}"
                                } else {
                                    def vp  = writeJSON(returnText:true, json:[
                                        name:vJob, max_concurrent_runs:1,
                                        parameters:[[name:'GROUP_ID',default:groupId],[name:'RUN_LAYER',default:vLayer]],
                                        tasks:[[task_key:"${vJob}_task", notebook_task:[notebook_path:vPath, base_parameters:[GROUP_ID:groupId, RUN_LAYER:vLayer], source:'WORKSPACE']]]
                                    ])
                                    def vf  = "/tmp/vjob_${System.currentTimeMillis()}.json"
                                    writeFile file:vf, text:vp
                                    def raw = sh(returnStdout:true, script:"curl -s -w \"\\n%{http_code}\" -X POST '${wsLocal.workspace_url}/api/2.1/jobs/create' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${vf}").trim()
                                    sh "rm -f ${vf}"
                                    def lines = raw.split('\n')
                                    if (lines[-1] != '200') error "View job create HTTP ${lines[-1]}"
                                    def vjson = readJSON text: lines[0..-2].join('\n')
                                        vJobId = vjson.job_id
                                    echo "  View job created: ${vJobId}"
                                }

                                def tp  = writeJSON(returnText:true, json:[job_id:vJobId, job_parameters:[GROUP_ID:groupId, RUN_LAYER:vLayer]])
                                def tf  = "/tmp/vtrig_${System.currentTimeMillis()}.json"
                                writeFile file:tf, text:tp
                                def tr  = sh(returnStdout:true, script:"curl -s -w \"\\n%{http_code}\" -X POST '${wsLocal.workspace_url}/api/2.1/jobs/run-now' -H 'Authorization: Bearer ${DB_TOKEN}' -H 'Content-Type: application/json' -d @${tf}").trim()
                                sh "rm -f ${tf}"
                                def tlines = tr.split('\n')
                                if (tlines[-1] != '200') error "View trigger HTTP ${tlines[-1]}"
                                def trjson = readJSON text: tlines[0..-2].join('\n')
                                def runId = trjson.run_id
                                echo "  ${vJob} triggered | run_id=${runId} | layer=${vLayer}"
                            }
                        }
                    }
                    parallel pMap
                }
            }
        }
    }

    post {
        always { echo "GROUP_ID:${params.GROUP_ID} | WORKSPACE:${params.WORKSPACE_OVERRIDE} | LAYER:${env.DETECTED_LAYER} | STATUS:${currentBuild.currentResult}" }
        success { echo "PIPELINE SUCCESS" }
        failure { echo "PIPELINE FAILED"  }
    }
}
