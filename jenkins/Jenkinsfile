// ============================================================
// Jenkinsfile — Multi-Workspace Databricks Pipeline
// ============================================================

pipeline {

    agent any

    parameters {

        choice(
            name: 'WORKSPACE',
            choices: ['ALL', 'karthik_workspace', 'MARAN_workspace', 'user3_workspace'],
            description: 'Select target workspace'
        )

        string(
            name: 'GROUP_ID',
            defaultValue: '',
            description: 'Enter GROUP_ID e.g. WEATHER_L0'
        )

        booleanParam(
            name: 'SYNC_GIT',
            defaultValue: true,
            description: 'Sync GitHub repo before execution'
        )

        booleanParam(
            name: 'CREATE_JOBS',
            defaultValue: true,
            description: 'Auto-create job if it does not exist'
        )

        booleanParam(
            name: 'WAIT_FOR_COMPLETION',
            defaultValue: true,
            description: 'Wait for Databricks job completion'
        )
    }

    environment {
        GITHUB_REPO   = 'https://github.com/ID-KARTHIKEYAN/DATA_INTEGRATION.git'
        GITHUB_BRANCH = 'main'
        POLL_INTERVAL = '15'
        MAX_WAIT_SECS = '1800'
    }

    stages {

        // ========================================================
        // STAGE 1 — VALIDATE
        // ========================================================

        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.GROUP_ID?.trim()) {
                        error "GROUP_ID must not be empty"
                    }
                    echo "GROUP_ID  : ${params.GROUP_ID}"
                    echo "WORKSPACE : ${params.WORKSPACE}"
                }
            }
        }

        // ========================================================
        // STAGE 2 — CHECKOUT REPO
        // ========================================================

        stage('Checkout Repo') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${env.GITHUB_BRANCH}"]],
                    userRemoteConfigs: [[url: env.GITHUB_REPO]]
                ])
                echo "Repo checked out"
            }
        }

        // ========================================================
        // STAGE 3 — LOAD WORKSPACE REGISTRY
        // ========================================================

        stage('Load Workspace Registry') {
            steps {
                script {
                    def rawText  = readFile('workspaces.json')
                    def registry = readJSON text: rawText

                    def selected = registry.workspaces.findAll { ws ->
                        ws.is_active &&
                        (params.WORKSPACE == 'ALL' || ws.name == params.WORKSPACE)
                    }

                    if (selected.isEmpty()) {
                        error "No active workspaces found for: ${params.WORKSPACE}"
                    }

                    env.SELECTED_WORKSPACES = writeJSON(returnText: true, json: selected)

                    echo "Selected workspaces:"
                    selected.each { echo "  - ${it.name}" }
                }
            }
        }

        // ========================================================
        // STAGE 4 — SYNC GIT REPOS
        // ========================================================

        stage('Sync Git Repos') {
            when { expression { return params.SYNC_GIT } }
            steps {
                script {
                    def rawText    = env.SELECTED_WORKSPACES
                    def workspaces = readJSON text: rawText

                    workspaces.each { ws ->
                        echo "Syncing : ${ws.name}"

                        withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {

                            def repoRaw  = sh(
                                returnStdout: true,
                                script: "curl -s -X GET '${ws.workspace_url}/api/2.0/repos' -H 'Authorization: Bearer ${DB_TOKEN}'"
                            ).trim()

                            def repoJson = readJSON text: repoRaw
                            def repo     = repoJson.repos?.find { it.path == ws.github_repo_path }

                            if (!repo) {
                                echo "Repo not found at ${ws.github_repo_path} — skipping sync"
                                return
                            }

                            def patchRaw = sh(
                                returnStdout: true,
                                script: """
                                    curl -s -w "\\n%{http_code}" \\
                                    -X PATCH '${ws.workspace_url}/api/2.0/repos/${repo.id}' \\
                                    -H 'Authorization: Bearer ${DB_TOKEN}' \\
                                    -H 'Content-Type: application/json' \\
                                    -d '{"branch":"${env.GITHUB_BRANCH}"}'
                                """
                            ).trim()

                            def patchLines = patchRaw.split('\n')
                            def patchCode  = patchLines[-1]

                            if (patchCode == '200') {
                                echo "Git sync OK : ${ws.name}"
                            } else {
                                echo "Git sync HTTP ${patchCode} on ${ws.name} — continuing"
                            }
                        }
                    }
                }
            }
        }

        // ========================================================
        // STAGE 4.5 — CREATE JOB IF NOT EXISTS
        // Pure REST from Jenkins — no notebook, no serverless
        // ========================================================

        stage('Create / Verify Jobs') {
            when { expression { return params.CREATE_JOBS } }
            steps {
                script {
                    def rawText     = env.SELECTED_WORKSPACES
                    def workspaces  = readJSON text: rawText
                    def parallelMap = [:]

                    workspaces.each { ws ->
                        parallelMap[ws.name] = {
                            withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {

                                echo "Create/Verify : ${ws.name} | ${params.GROUP_ID}"

                                // ── List existing jobs ────────────────────────
                                def listRaw  = sh(
                                    returnStdout: true,
                                    script: "curl -s -X GET '${ws.workspace_url}/api/2.1/jobs/list?limit=100' -H 'Authorization: Bearer ${DB_TOKEN}'"
                                ).trim()

                                def listJson    = readJSON text: listRaw
                                def existingJob = listJson.jobs?.find { j ->
                                    j.settings?.name == params.GROUP_ID
                                }

                                if (existingJob) {
                                    ws.job_id = existingJob.job_id
                                    echo "Job exists — job_id: ${ws.job_id}"

                                } else {
                                    echo "Job not found — creating..."

                                    def notebookPath = "${ws.github_repo_path}/notebooks/run_framework"

                                    def createRaw = sh(
                                        returnStdout: true,
                                        script: """
                                            curl -s -w "\\n%{http_code}" \\
                                            -X POST '${ws.workspace_url}/api/2.1/jobs/create' \\
                                            -H 'Authorization: Bearer ${DB_TOKEN}' \\
                                            -H 'Content-Type: application/json' \\
                                            -d '{
                                              "name": "${params.GROUP_ID}",
                                              "max_concurrent_runs": 1,
                                              "parameters": [{"name":"GROUP_ID","default":"${params.GROUP_ID}"}],
                                              "tasks": [{
                                                "task_key": "${params.GROUP_ID}_task",
                                                "notebook_task": {
                                                  "notebook_path": "${notebookPath}",
                                                  "base_parameters": {"GROUP_ID":"${params.GROUP_ID}"},
                                                  "source": "WORKSPACE"
                                                },
                                                "environment_key": "default_env"
                                              }],
                                              "environments": [{
                                                "environment_key": "default_env",
                                                "spec": {"client":"1"}
                                              }]
                                            }'
                                        """
                                    ).trim()

                                    def createLines = createRaw.split('\n')
                                    def createCode  = createLines[-1]
                                    def createBody  = createLines[0..-2].join('\n')

                                    if (createCode != '200') {
                                        error "Job creation failed on ${ws.name} HTTP ${createCode} : ${createBody}"
                                    }

                                    def createJson = readJSON text: createBody
                                    ws.job_id      = createJson.job_id

                                    echo "Job created — job_id: ${ws.job_id}"
                                }
                            }
                        }
                    }

                    parallel parallelMap

                    env.SELECTED_WORKSPACES = writeJSON(returnText: true, json: workspaces)
                }
            }
        }

        // ========================================================
        // STAGE 5 — TRIGGER DATABRICKS JOBS
        // ========================================================

        stage('Trigger Databricks Jobs') {
            steps {
                script {
                    def rawText     = env.SELECTED_WORKSPACES
                    def workspaces  = readJSON text: rawText
                    def parallelMap = [:]
                    def runIds      = [:]

                    workspaces.each { ws ->
                        parallelMap[ws.name] = {
                            withCredentials([string(credentialsId: ws.credential_id, variable: 'DB_TOKEN')]) {

                                echo "Triggering ${ws.name} | job_id: ${ws.job_id}"

                                def trigRaw = sh(
                                    returnStdout: true,
                                    script: """
                                        curl -s -w "\\n%{http_code}" \\
                                        -X POST '${ws.workspace_url}/api/2.1/jobs/run-now' \\
                                        -H 'Authorization: Bearer ${DB_TOKEN}' \\
                                        -H 'Content-Type: application/json' \\
                                        -d '{"job_id":${ws.job_id},"job_parameters":{"GROUP_ID":"${params.GROUP_ID}"}}'
                                    """
                                ).trim()

                                def trigLines = trigRaw.split('\n')
                                def trigCode  = trigLines[-1]
                                def trigBody  = trigLines[0..-2].join('\n')

                                if (trigCode != '200') {
                                    error "Trigger failed on ${ws.name} HTTP ${trigCode} : ${trigBody}"
                                }

                                def trigJson = readJSON text: trigBody
                                def runId    = trigJson.run_id

                                echo "Triggered — run_id: ${runId}"

                                runIds[ws.name] = [
                                    run_id       : runId,
                                    workspace_url: ws.workspace_url,
                                    credential_id: ws.credential_id
                                ]
                            }
                        }
                    }

                    parallel parallelMap

                    env.RUN_IDS = writeJSON(returnText: true, json: runIds)
                }
            }
        }

        // ========================================================
        // STAGE 6 — WAIT FOR COMPLETION
        // ========================================================

        stage('Wait For Completion') {
            when { expression { return params.WAIT_FOR_COMPLETION } }
            steps {
                script {
                    def rawText    = env.RUN_IDS
                    def runIds     = readJSON text: rawText
                    def allPassed  = true
                    def failedList = []

                    runIds.each { wsName, info ->
                        echo "Polling : ${wsName}"

                        withCredentials([string(credentialsId: info.credential_id, variable: 'DB_TOKEN')]) {

                            def elapsed = 0
                            def done    = false
                            def lcState = ''
                            def rsState = ''

                            while (!done && elapsed < Integer.parseInt(env.MAX_WAIT_SECS)) {

                                sleep(Integer.parseInt(env.POLL_INTERVAL))
                                elapsed += Integer.parseInt(env.POLL_INTERVAL)

                                def pollRaw  = sh(
                                    returnStdout: true,
                                    script: "curl -s -X GET '${info.workspace_url}/api/2.1/jobs/runs/get?run_id=${info.run_id}' -H 'Authorization: Bearer ${DB_TOKEN}'"
                                ).trim()

                                def pollJson = readJSON text: pollRaw
                                def stateObj = pollJson.state

                                lcState = stateObj?.life_cycle_state ?: 'UNKNOWN'
                                rsState = stateObj?.result_state     ?: ''

                                echo "${wsName} | ${lcState} | ${rsState}"

                                if (['TERMINATED','SKIPPED','INTERNAL_ERROR'].contains(lcState)) {
                                    done = true
                                }
                            }

                            if (!done) {
                                failedList << "${wsName} (TIMEOUT)"
                                allPassed = false
                            } else if (rsState != 'SUCCESS') {
                                failedList << "${wsName} (${rsState})"
                                allPassed = false
                            } else {
                                echo "${wsName} — SUCCESS"
                            }
                        }
                    }

                    if (!allPassed) {
                        error "Failed workspaces: ${failedList.join(', ')}"
                    }

                    echo "All workspaces completed successfully"
                }
            }
        }
    }

    post {
        always {
            echo "GROUP_ID: ${params.GROUP_ID} | WORKSPACE: ${params.WORKSPACE} | STATUS: ${currentBuild.currentResult}"
        }
        success { echo "PIPELINE SUCCESS" }
        failure { echo "PIPELINE FAILED" }
    }
}
